#!/usr/bin/env node
'use strict'
/*
 * hyperpower-tui — run Claude Code so the per-agent progress bar appears INSIDE
 * the native /workflows table, in one UI, WITHOUT patching anything.
 *
 * How: Claude's TUI is rendered by its signed Bun binary (un-patchable). So we sit
 * on its OUTPUT stream instead. We give Claude a real PTY via `script` (so it draws
 * its full-screen TUI), pass every byte through to your terminal unchanged, and in
 * parallel feed those bytes into a tiny ANSI screen model (bin/hpw-screen.js). After
 * each frame settles we OVERLAY a small bar into the gap of every workflow node row
 * (between the model name and the token field) with cursor-positioned writes, then
 * restore the cursor. Claude redraws on its next frame; we re-overlay. Input is
 * passed straight through.
 *
 * Usage:  hyperpower-tui [..claude args]    e.g.  hyperpower-tui   (then use it normally)
 *
 * This is an OUTPUT overlay: fragile by nature (depends on Claude's row layout) and
 * best-effort. The bar reflects each row's own visible state (✔ done / ⏺ running /
 * ○ queued) — honest activity, not a fake %.
 */
const { spawn } = require('child_process')
const path = require('path')
const { StringDecoder } = require('string_decoder')
const { Screen, planOverlay } = require(path.join(__dirname, 'hpw-screen.js'))

const claudeArgs = process.argv.slice(2)
const out = process.stdout
let cols = out.columns || 200
let rows = out.rows || 50
let screen = new Screen(rows, cols)
let frame = 0
let overlayTimer = null
let lastByteAt = 0
const decoder = new StringDecoder('utf8') // handles multi-byte glyphs split across chunks

function findRealClaude() {
  // Resolve a non-cmux, non-self `claude` on PATH (mirror cmux's own logic).
  const selfDir = __dirname
  for (const d of (process.env.PATH || '').split(':')) {
    if (!d || d === selfDir) continue
    const p = path.join(d, 'claude')
    try { require('fs').accessSync(p, require('fs').constants.X_OK); if (p !== process.argv[1]) return p } catch {}
  }
  return 'claude'
}

function emitOverlay() {
  const s = planOverlay(screen, frame)
  if (s) out.write(s)
}
function scheduleOverlay() {
  if (overlayTimer) return
  overlayTimer = setTimeout(() => { overlayTimer = null; emitOverlay() }, 40)
}

// Animate running bars on a steady tick — but ONLY when the frame has settled
// (no bytes for ~60ms), so we never inject between Claude's own cursor moves.
const anim = setInterval(() => {
  frame++
  if (Date.now() - lastByteAt > 60) emitOverlay()
}, 250)

const claude = findRealClaude()
// macOS `script -q <file> <cmd> [args]` allocates a PTY for <cmd> and copies its
// output to our stdout pipe. file=/dev/null discards the typescript. Our stdin is
// inherited so keystrokes reach Claude; stderr inherited.
const child = spawn('script', ['-q', '/dev/null', claude, ...claudeArgs], {
  stdio: ['inherit', 'pipe', 'inherit'],
  env: process.env,
})

child.stdout.on('data', (buf) => {
  out.write(buf)                       // 1) pass Claude's bytes through untouched
  screen.write(decoder.write(buf))     // 2) update shadow model (UTF-8-boundary safe)
  lastByteAt = Date.now()
  scheduleOverlay()                    // 3) re-overlay shortly after the frame settles
})

process.stdout.on('resize', () => {
  cols = out.columns || cols; rows = out.rows || rows
  screen = new Screen(rows, cols) // reset shadow model on resize; Claude will redraw
})

child.on('exit', (code, sig) => {
  clearInterval(anim); if (overlayTimer) clearTimeout(overlayTimer)
  process.exit(code == null ? (sig ? 1 : 0) : code)
})
child.on('error', (e) => {
  clearInterval(anim)
  process.stderr.write('hyperpower-tui: failed to launch (' + e.message + ')\n')
  process.exit(127)
})
